    { "name": "boons",   "label": "Boons",   "system": "openlegend_jd", "path": "./packs/boons",   "type": "Item",        "private": false },
    { "name": "feats",   "label": "Feats",   "system": "openlegend_jd", "path": "./packs/feats",   "type": "Item",        "private": false },
    { "name": "flaws",   "label": "Flaws",   "system": "openlegend_jd", "path": "./packs/flaws",   "type": "Item",        "private": false },
    { "name": "gm-feats","label": "GM-Feats","system": "openlegend_jd", "path": "./packs/gm-feats","type": "Item",        "private": false },
    { "name": "perks",   "label": "Perks",   "system": "openlegend_jd", "path": "./packs/perks",   "type": "Item",        "private": false },
    { "name": "rules",   "label": "Rules",   "system": "openlegend_jd", "path": "./packs/rules",   "type": "JournalEntry","private": false },
    { "name": "weapons", "label": "Weapons", "system": "openlegend_jd", "path": "./packs/weapons", "type": "Item",        "private": false },
    { "name": "armor",   "label": "Armor",   "system": "openlegend_jd", "path": "./packs/armor",   "type": "Item",        "private": false },
    { "name": "gm-screen","label": "GM-Screen","system": "openlegend_jd","path": "./packs/gm-screen","type": "JournalEntry","private": false }
  ],
  "socket": false,
  "protected": false,
  "grid": { "distance": 5, "units": "ft" },
  "primaryTokenAttribute": "defense.hp",
  "flags": {
    "hotReload": {
      "extensions": ["css", "html", "json", "js"],
      "paths": ["css", "lang", "module", "templates"]
    }
  }
